#include <iostream>
using namespace std;

int main()
{
    int numbers[] = {109,99,23,45,23,2,5,1};

    int size = 8;
    int temp;

    // Bubble Sort
    for(int i = 0; i < size - 1; i++)
    {
        for(int j = 0; j < size - i - 1; j++)
        {
            if(numbers[j] > numbers[j + 1])
            {
                temp = numbers[j];
                numbers[j] = numbers[j + 1];
                numbers[j + 1] = temp;
            }
        }
    }

    // Display result
    cout << "Numbers in ascending order:\n";

    for(int i = 0; i < size; i++)
    {
        cout << numbers[i] << " ";
    }

    return 0;
}
